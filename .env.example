# Admin authentication key (set in Vercel env vars for production)
# In dev, copy to .env.local and set your own value
VITE_ADMIN_KEY=your-secret-admin-key

# Pipeline source directory overrides (optional)
# Set these if your data exports live outside the default locations
# INSTAGRAM_EXPORT_DIR=C:/path/to/your/instagram-export
# CARBONMADE_ARCHIVE_DIR=C:/path/to/your/carbonmade-archive

# Supabase (optional — app works without these, cloud sync disabled)
# Create a project at https://supabase.com, copy from Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# OpenAI (optional — Glint AI chat disabled without this)
# Get a key at https://platform.openai.com/api-keys
# Set as Vercel env var (NOT prefixed with VITE_ — server-side only)
OPENAI_API_KEY=your-openai-api-key
